# scripts/create-subsidiary.sh が読み込む設定ファイル。
#
# 配置先（実体）:   ~/.config/ai-company-template/config.env
# このファイル自体は雛形。コピーして値を埋めてください:
#
#   mkdir -p ~/.config/ai-company-template
#   cp scripts/config.env.example ~/.config/ai-company-template/config.env
#   chmod 600 ~/.config/ai-company-template/config.env
#   $EDITOR ~/.config/ai-company-template/config.env
#
# 注意: 実体ファイルは Notion の Internal Integration Token を含むため、
#       Git にも、その他のクラウド同期にも置かないこと。
# ---------------------------------------------------------------

# Notion Integration の Internal token（ntn_... または secret_...）
# 取得手順: https://www.notion.so/my-integrations →「+ New integration」
NOTION_API_KEY=

# 「AI会社」親ページの ID（32文字、ハイフンなし）
# Notion で親ページを開き URL からコピー:
#   https://www.notion.so/<workspace>/<TITLE>-<32文字ID>?...
# 末尾の 32文字（ハイフンを除いたもの）を貼ること。
# 親ページには Integration を「Connect」しておく必要があります。
NOTION_PARENT_PAGE_ID=

# GitHub の owner（個人アカウントなら GitHub username、Org ならその名前）
# 省略時は `gh api user --jq .login` が使われます。
GITHUB_OWNER=
